{
  "manifest_version": 3,
  "name": "Mapfeel",
  "version": "1.5",
  "description": "Cosenseプロジェクトの位置情報ページを地図上に表示",
  "action": {
    "default_icon": {
      "48": "mapfeel_icon_48.png",
      "128": "mapfeel_icon_128.png"
    },
    "default_title": "Mapfeel"
  },
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "host_permissions": [
    "https://scrapbox.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
"content_scripts": [
    {
      "matches": ["https://scrapbox.io/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["jquery.min.js", "leaflet.js", "leaflet.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "mapfeel_icon_48.png",
    "128": "mapfeel_icon_128.png"
  }
}
